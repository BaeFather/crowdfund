<script>
$(document).ready(function(){
	//faq 질문 클릭시 내용 오픈
	$('.FAQ dl').click(function(){
		if($(this).hasClass('on')){
			$(this).removeClass('on').css({background:'url(<?=G5_THEME_URL?>/img2/bbs/arrow_down.gif) no-repeat right 1px', backgroundSize:'25px auto'}).find('dd').slideUp('fast');
		}else{
			$(this).addClass('on').css({background:'url(<?=G5_THEME_URL?>/img2/bbs/arrow_up.gif) no-repeat right 1px',backgroundSize:'25px auto'}).find('dd').slideDown('fast');
			$(this).siblings().removeClass('on').css({background:'url(<?=G5_THEME_URL?>/img2/bbs/arrow_down.gif) no-repeat right 1px', backgroundSize:'25px auto'}).find('dd').slideUp('fast');
		}
	});

	//탭 기능
	$('.FAQ:eq(0)').show();
	$('.tab_type02 li').click(function(){
		var cur = $(this).index();
		$(this).addClass('on').siblings().removeClass('on');
		$('.FAQ').hide();
		$('.FAQ:eq('+cur+')').show();
	});

});
</script>



