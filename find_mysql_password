./lib/crypt.lib.php:<?//** ҫЖАМіЬ DGuard ҫПИЈИӯ **//function DGuardEncrypt($text){	$text = trim($text);	$enc_data = '';	if(function_exists('pdg_encrypt') && strlen($text)) {		$enc_data = pdg_encrypt("TBL", "ENC", $text);					//TBL-ENC Б¶ЗХҪГ ҫз№жЗв ҫПИЈИӯ (ҫЛ°нё®Бт:ARIA256 / ёрөе:CBC) : TBL-PWD Б¶ЗХҪГ ҙЬ№жЗв ҫПИЈИӯ (ҫЛ°нё®Бт:SHA256) -> ә№ИЈИӯ әТ°Ў	}	return $enc_data;}//** ҫЖАМіЬ DGuard ә№ИЈИӯ **//function DGuardDecrypt($encText){	$encText = trim($encText);	$dec_data = '';	if(function_exists('pdg_decrypt') && strlen($encText)) {		$dec_data = pdg_decrypt("TBL", "ENC", $encText);	}	return $dec_data;}// ** ҫПИЈИӯЕ°ёҰ ГЯГвЗПҝ© ҫПИЈИӯ ** //// ГЦБҫ ҫПИЈИӯ °ӘА» base64 ҝЈДЪөщ ИД №ЭИҜ.// ҫПИЈИӯ№жҪД = ($isRSA==1) ? RSA(әсҙлДӘҫПИЈИӯ) : AES256(ҙлДӘҫПИЈИӯ);function masterEncrypt($text, $isRSA=0){	global $CONF;	if(trim($text)=='') {		return false;	}	else {		if( $isRSA ) {			$pbkey = LoadKey("pb", $CONF['LoadKeyPwd']);	// ҫПИЈИӯЕ° ГЯГв			$pubkey_decoded = openssl_pkey_get_public($pbkey);			if($pubkey_decoded === false) return false;			$ciphertext = false;			$status = @openssl_public_encrypt($text, $ciphertext, $pubkey_decoded);			if(!$status || $ciphertext === false) return false;			return base64_encode($ciphertext);		}		else {			$pvkey = LoadKey("pv", $CONF['LoadKeyPwd']);	// ҫПИЈИӯЕ° ГЯГв			$key = hash('MD5', $pvkey, true);			return base64_encode(openssl_encrypt($text, "aes-256-cbc", $key, true, str_repeat(chr(0), 16)));		}	}}// ** ә№ИЈИӯЕ°ёҰ ГЯГвЗПҝ© ә№ИЈИӯ ** //// Жт№® №ЭИҜfunction masterDecrypt($ciphertext, $isRSA=0){	global $CONF;	if(trim($ciphertext)=='') {		return false;	}	else {		$pvkey = LoadKey("pv", $CONF['LoadKeyPwd']);	// ә№ИЈИӯЕ° ГЯГв		if( $isRSA ) {			$password = NULL;			$ciphertext = base64_decode($ciphertext, true);			if($ciphertext === false) return false;			$privkey_decoded = openssl_pkey_get_private($pvkey, $password);			if($privkey_decoded === false) return false;			$plaintext = false;			$status = openssl_private_decrypt($ciphertext, $plaintext, $privkey_decoded);			@openssl_pkey_free($privkey_decoded);			if(!$status || $plaintext === false) return false;			return $plaintext;		}		else {			$key = hash('MD5', $pvkey, true);			$plaintext = openssl_decrypt(base64_decode($ciphertext), "aes-256-cbc", $key, true, str_repeat(chr(0), 16));			return $plaintext;		}	}}// ** ҝЬәОDBјӯ№цҝЎ ҫПИЈИӯ өИ ҫП.ә№ИЈИӯЕ°ёҰ Жт№®Аё·О ГЯГв ** //function LoadKey($key_type, $password) {	if($key_type && in_array($key_type, array('pv','pb'))) {		if( defined('G5_MYSQL_HOST2') && defined('G5_MYSQL_USER2') && defined('G5_MYSQL_PASSWORD2') && defined('G5_MYSQL_DB2') ) {			$linkX = sql_connect(G5_MYSQL_HOST2, G5_MYSQL_USER2, G5_MYSQL_PASSWORD2, G5_MYSQL_DB2) or die('DB2 Connect Error!!!');			$sql = "				SELECT					AES_DECRYPT(UNHEX(".$key_type."),'".get_encrypt_string2($password)."') AS ".$key_type."				FROM					secure_key				ORDER BY					rdate DESC LIMIT 1";			$SECURE_KEY = sql_fetch($sql, "", $linkX);			return $SECURE_KEY[$key_type];			sql_close($linkX);		}		else {			return false;		}	}	else {		return false;	}}?>
